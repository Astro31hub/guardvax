{
    "name": "guardvax/hospital-system",
    "description": "GuardVAX Hospital Vaccination & Health Data Management System",
    "type": "project",
    "require": {
        "php": ">=8.0",
        "dompdf/dompdf": "^2.0",
        "ext-pdo_mysql": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "phpmailer/phpmailer": "^6.9"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5"
    },
    "autoload": {
        "psr-4": {
            "GuardVAX\\": "src/"
        }
    },
    "config": {
        "platform": {
            "php": "8.4.0"
        },
        "allow-plugins": {
            "composer/installers": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}